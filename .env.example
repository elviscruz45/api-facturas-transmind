# =============================================================
#  .env.example — Copia este archivo como .env y completa los valores
#  cp .env.example .env
# =============================================================

# ── Google Cloud ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=tu-project-id                        # ej: facturacion-484614
# Solo para desarrollo local (en GCP Cloud Run no es necesario)
GOOGLE_APPLICATION_CREDENTIALS=./facturacion-XXXXX-XXXX.json

# ── Gemini / Vertex AI ────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_LOCATION=us-central1
GEMINI_CONCURRENCY_LIMIT=2
GEMINI_TIMEOUT_SECONDS=180

# ── Cloud Storage ─────────────────────────────────────────────
STORAGE_BUCKET_NAME=tu-proyecto-invoices                  # ej: facturacion-484614-invoices

# ── API ───────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=300
DEBUG=false
PORT=8080

# ── Supabase (base de datos) ──────────────────────────────────
NAME_SUPABASE_PROJECT=nombre-del-proyecto
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DB_PASSWORD=tu-password-de-supabase

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
